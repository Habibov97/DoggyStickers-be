<html>
  <head>
    <meta charset='UTF-8' />
    <title>Reset Password</title>
  </head>

  <body style='margin:0; padding:0; background-color:#f4f4f4; font-family:Arial, sans-serif;'>

    <table width='100%' cellpadding='0' cellspacing='0' style='background-color:#f4f4f4; padding: 20px 0;'>
      <tr>
        <td align='center'>

          <!-- Container -->
          <table
            width='600'
            cellpadding='0'
            cellspacing='0'
            style='background:#ffffff; border-radius:8px; padding:40px;'
          >

            <!-- Title -->
            <tr>
              <td align='center' style='padding-bottom:20px;'>
                <h2 style='margin:0; color:#333;'>Reset Your Password</h2>
              </td>
            </tr>

            <!-- Greeting -->
            <tr>
              <td style='color:#555; font-size:16px; padding-bottom:20px;'>
                Hi
                {{user.username}},
              </td>
            </tr>

            <!-- Message -->
            <tr>
              <td style='color:#555; font-size:15px; line-height:1.6; padding-bottom:30px;'>
                You requested to reset your password. Click the button below to proceed.
              </td>
            </tr>

            <!-- Button -->
            <tr>
              <td align='center' style='padding-bottom:30px;'>
                <a
                  href='{{resetUrl}}'
                  style='
                     background-color:#4CAF50;
                     color:#ffffff;
                     padding:14px 24px;
                     text-decoration:none;
                     border-radius:5px;
                     display:inline-block;
                     font-size:16px;
                     font-weight:bold;
                   '
                >
                  Reset Password
                </a>
              </td>
            </tr>

            <!-- Expire -->
            <tr>
              <td style='color:#999; font-size:14px; padding-bottom:20px;'>
                This link will expire in
                {{expireTime}}
                minutes.
              </td>
            </tr>
            <!-- Footer -->
            <tr>
              <td style='color:#aaa; font-size:12px; text-align:center;'>
                If you didn’t request this, you can safely ignore this email.
              </td>
            </tr>

          </table>

        </td>
      </tr>
    </table>

  </body>
</html>